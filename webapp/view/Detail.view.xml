<mvc:View
    controllerName="com.alihaydarsayar.demo.zfiorieventmng.controller.Detail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:uxap="sap.uxap"
    xmlns:form="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    xmlns="sap.m">

    <Page
        id="detailPage"
        title="{i18n>detailTitle}"
        showNavButton="true"
        navButtonPress=".onNavBack"
        enableScrolling="false"
        class="sapUiNoContentPadding">

        <uxap:ObjectPageLayout
            id="objectPage"
            showTitleInHeaderContent="true"
            headerContentPinnable="true"
            upperCaseAnchorBar="false"
            showFooter="true">

            <!-- Başlık -->
            <uxap:headerTitle>
                <uxap:ObjectPageDynamicHeaderTitle>
                    <uxap:heading>
                        <VBox>
                            <Title text="{em>trackingId}" level="H1"/>
                            <Text text="{em>description}" class="sapUiTinyMarginTop"/>
                        </VBox>
                    </uxap:heading>
                    <uxap:snappedContent>
                        <ObjectStatus
                            text="{ path: 'em>status', formatter: '.formatter.statusText' }"
                            state="{ path: 'em>status', formatter: '.formatter.statusState' }"
                            icon="{ path: 'em>status', formatter: '.formatter.statusIcon' }"/>
                    </uxap:snappedContent>
                    <uxap:actions>
                        <Button
                            text="{i18n>reportEvent}"
                            type="Emphasized"
                            icon="sap-icon://add-activity"
                            press=".onOpenReportDialog"/>
                    </uxap:actions>
                </uxap:ObjectPageDynamicHeaderTitle>
            </uxap:headerTitle>

            <!-- Başlık içeriği: özet göstergeler -->
            <uxap:headerContent>
                <FlexBox wrap="Wrap" alignItems="Start" class="emHeaderFacts">
                    <VBox class="emFact">
                        <Label text="{i18n>colStatus}"/>
                        <ObjectStatus
                            text="{ path: 'em>status', formatter: '.formatter.statusText' }"
                            state="{ path: 'em>status', formatter: '.formatter.statusState' }"
                            icon="{ path: 'em>status', formatter: '.formatter.statusIcon' }"
                            class="emFactValue"/>
                    </VBox>
                    <VBox class="emFact">
                        <Label text="{i18n>lblDelay}"/>
                        <ObjectStatus
                            text="{ path: 'em>delayHours', formatter: '.formatter.delayText' }"
                            state="{ path: 'em>delayHours', formatter: '.formatter.delayState' }"
                            class="emFactValue"/>
                    </VBox>
                    <VBox class="emFact">
                        <Label text="{i18n>lblCurrentLocation}"/>
                        <Text text="{em>currentLocation}" class="emFactValue"/>
                    </VBox>
                    <VBox class="emFact">
                        <Label text="{i18n>lblPlannedEnd}"/>
                        <Text text="{ path: 'em>plannedEnd', formatter: '.formatter.dateTime' }" class="emFactValue"/>
                    </VBox>
                    <VBox class="emFact emFactWide">
                        <Label text="{i18n>lblProgress}"/>
                        <ProgressIndicator
                            percentValue="{em>progress}"
                            displayValue="{em>progress}%"
                            showValue="true"
                            state="{ path: 'em>status', formatter: '.formatter.progressState' }"
                            class="emFactValue"/>
                    </VBox>
                </FlexBox>
            </uxap:headerContent>

            <uxap:sections>

                <!-- Genel bilgiler -->
                <uxap:ObjectPageSection title="{i18n>sectionGeneral}" titleUppercase="false">
                    <uxap:subSections>
                        <uxap:ObjectPageSubSection titleUppercase="false">
                            <form:SimpleForm
                                editable="false"
                                layout="ResponsiveGridLayout"
                                labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                                columnsXL="2" columnsL="2"
                                singleContainerFullSize="false">
                                <Label text="{i18n>lblEventId}"/>
                                <Text text="{em>id}"/>
                                <Label text="{i18n>lblType}"/>
                                <Text text="{em>type}"/>
                                <Label text="{i18n>lblPartner}"/>
                                <Text text="{em>partner}"/>
                                <Label text="{i18n>lblCarrier}"/>
                                <Text text="{em>carrier}"/>
                                <Label text="{i18n>lblPriority}"/>
                                <Text text="{em>priority}"/>

                                <Label text="{i18n>lblOrigin}"/>
                                <Text text="{em>origin}"/>
                                <Label text="{i18n>lblDestination}"/>
                                <Text text="{em>destination}"/>
                                <Label text="{i18n>lblPlannedStart}"/>
                                <Text text="{ path: 'em>plannedStart', formatter: '.formatter.dateTime' }"/>
                                <Label text="{i18n>lblPlannedEnd}"/>
                                <Text text="{ path: 'em>plannedEnd', formatter: '.formatter.dateTime' }"/>
                                <Label text="{i18n>lblActualEnd}"/>
                                <ObjectStatus
                                    text="{ path: 'em>actualEnd', formatter: '.formatter.actualEndText' }"
                                    state="{ path: 'em>actualEnd', formatter: '.formatter.actualEndState' }"/>
                            </form:SimpleForm>
                        </uxap:ObjectPageSubSection>
                    </uxap:subSections>
                </uxap:ObjectPageSection>

                <!-- Nakliye ve navlun -->
                <uxap:ObjectPageSection title="{i18n>sectionFreight}" titleUppercase="false">
                    <uxap:subSections>

                        <uxap:ObjectPageSubSection title="{i18n>subSectionVoyage}" titleUppercase="false">
                            <VBox>
                            <MessageStrip
                                text="{i18n>noFreight}"
                                type="Information"
                                showIcon="true"
                                visible="{= !${em>freight} }"/>
                            <form:SimpleForm
                                editable="false"
                                layout="ResponsiveGridLayout"
                                labelSpanXL="4" labelSpanL="4" labelSpanM="4" labelSpanS="12"
                                columnsXL="2" columnsL="2"
                                singleContainerFullSize="false"
                                visible="{= !!${em>freight} }">
                                <Label text="{i18n>lblMode}"/>
                                <HBox alignItems="Center">
                                    <core:Icon src="{em>freight/modeIcon}" class="emModeIcon"/>
                                    <Text text="{em>freight/mode}"/>
                                </HBox>
                                <Label text="{i18n>lblVoyageNo}"/>
                                <ObjectIdentifier title="{em>freight/voyageNo}"/>
                                <Label text="{i18n>lblVessel}"/>
                                <Text text="{em>freight/vessel}"/>
                                <Label text="{i18n>lblTransportDoc}"/>
                                <Text text="{em>freight/transportDoc}"/>
                                <Label text="{i18n>lblDriver}"/>
                                <Text text="{= ${em>freight/driver} || '-' }"/>

                                <Label text="{i18n>lblCarrier}"/>
                                <Text text="{em>carrier}"/>
                                <Label text="{i18n>lblChargeableWeight}"/>
                                <Text text="{em>freight/chargeableWeight}"/>
                                <Label text="{i18n>lblVolume}"/>
                                <Text text="{em>freight/volume}"/>
                                <Label text="{i18n>lblPackages}"/>
                                <Text text="{em>freight/packages}"/>
                                <Label text="{i18n>lblFreightTotal}"/>
                                <ObjectNumber
                                    number="{ parts: ['em>freight/total', 'em>freight/currency'], formatter: '.formatter.currency' }"
                                    emphasized="true"/>
                            </form:SimpleForm>
                            </VBox>
                        </uxap:ObjectPageSubSection>

                        <uxap:ObjectPageSubSection title="{i18n>subSectionRoute}" titleUppercase="false" visible="{= !!${em>freight} }">
                            <Table items="{em>freight/route}" showSeparators="Inner">
                                <columns>
                                    <Column width="4rem" hAlign="Center">
                                        <Text text="{i18n>colStopSeq}"/>
                                    </Column>
                                    <Column>
                                        <Text text="{i18n>colStopName}"/>
                                    </Column>
                                    <Column width="8rem" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline">
                                        <Text text="{i18n>colStopRole}"/>
                                    </Column>
                                    <Column width="11rem" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline">
                                        <Text text="{i18n>colStopPlanned}"/>
                                    </Column>
                                    <Column width="11rem" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline">
                                        <Text text="{i18n>colStopActual}"/>
                                    </Column>
                                    <Column width="10rem">
                                        <Text text="{i18n>colStopStatus}"/>
                                    </Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Text text="{em>seq}"/>
                                            <ObjectIdentifier title="{em>name}"/>
                                            <Text text="{em>role}"/>
                                            <Text text="{ path: 'em>planned', formatter: '.formatter.dateTime' }"/>
                                            <Text text="{ path: 'em>actual', formatter: '.formatter.dateTime' }"/>
                                            <ObjectStatus
                                                text="{ path: 'em>status', formatter: '.formatter.stopStateText' }"
                                                state="{ path: 'em>status', formatter: '.formatter.stopState' }"
                                                icon="{ path: 'em>status', formatter: '.formatter.stopIcon' }"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </uxap:ObjectPageSubSection>

                        <uxap:ObjectPageSubSection title="{i18n>subSectionCost}" titleUppercase="false" visible="{= !!${em>freight} }">
                            <VBox>
                            <Table items="{em>freight/costItems}" showSeparators="Inner">
                                <columns>
                                    <Column>
                                        <Text text="{i18n>colCostItem}"/>
                                    </Column>
                                    <Column width="12rem" hAlign="End">
                                        <Text text="{i18n>colCostAmount}"/>
                                    </Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Text text="{em>text}"/>
                                            <ObjectNumber
                                                number="{ parts: ['em>amount', 'em>currency'], formatter: '.formatter.currency' }"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                            <Toolbar class="emCostTotalBar">
                                <ToolbarSpacer/>
                                <Label text="{i18n>lblFreightTotal}" design="Bold"/>
                                <ObjectNumber
                                    number="{ parts: ['em>freight/total', 'em>freight/currency'], formatter: '.formatter.currency' }"
                                    emphasized="true"
                                    class="sapUiTinyMarginBegin"/>
                            </Toolbar>
                            </VBox>
                        </uxap:ObjectPageSubSection>

                    </uxap:subSections>
                </uxap:ObjectPageSection>

                <!-- Olay akışı (zaman çizelgesi) -->
                <uxap:ObjectPageSection title="{i18n>sectionTimeline}" titleUppercase="false">
                    <uxap:subSections>
                        <uxap:ObjectPageSubSection titleUppercase="false">
                            <List
                                items="{em>events}"
                                showSeparators="None"
                                class="emTimeline">
                                <CustomListItem>
                                    <HBox alignItems="Start" class="emTimelineRow">
                                        <core:Icon
                                            src="{ path: 'em>state', formatter: '.formatter.eventIcon' }"
                                            color="{ path: 'em>state', formatter: '.formatter.eventIconColor' }"
                                            class="emTimelineIcon"/>
                                        <VBox class="emTimelineBody">
                                            <HBox alignItems="Center" wrap="Wrap" class="emTimelineHead">
                                                <Title text="{em>name}" level="H4" wrapping="true"/>
                                                <ObjectStatus
                                                    text="{ path: 'em>state', formatter: '.formatter.eventStateText' }"
                                                    state="{ path: 'em>state', formatter: '.formatter.eventStateValue' }"
                                                    class="sapUiTinyMarginBegin"/>
                                            </HBox>
                                            <Text
                                                text="{ path: 'em>at', formatter: '.formatter.dateTime' }"
                                                class="emTimelineMeta"/>
                                            <Text text="{em>location}" class="emTimelineMeta"/>
                                            <Text
                                                text="{em>note}"
                                                visible="{= !!${em>note} }"
                                                class="emTimelineNote"/>
                                            <Text
                                                text="{ parts: ['i18n>reportedBy', 'em>reportedBy'], formatter: '.formatter.reportedByText' }"
                                                visible="{= !!${em>reportedBy} }"
                                                class="emTimelineMeta"/>
                                        </VBox>
                                    </HBox>
                                </CustomListItem>
                            </List>
                        </uxap:ObjectPageSubSection>
                    </uxap:subSections>
                </uxap:ObjectPageSection>

                <!-- İstisnalar -->
                <uxap:ObjectPageSection title="{i18n>sectionExceptions}" titleUppercase="false">
                    <uxap:subSections>
                        <uxap:ObjectPageSubSection titleUppercase="false">
                            <VBox>
                            <MessageStrip
                                text="{i18n>noExceptions}"
                                type="Success"
                                showIcon="true"
                                visible="{= ${em>exceptions}.length === 0 }"/>
                            <List
                                items="{em>exceptions}"
                                showSeparators="None"
                                visible="{= ${em>exceptions}.length > 0 }">
                                <CustomListItem>
                                    <VBox class="emExceptionItem">
                                        <MessageStrip
                                            text="{em>text}"
                                            type="{em>severity}"
                                            showIcon="true"/>
                                        <Text
                                            text="{ path: 'em>at', formatter: '.formatter.dateTime' }"
                                            class="emTimelineMeta sapUiTinyMarginTop"/>
                                    </VBox>
                                </CustomListItem>
                            </List>
                            </VBox>
                        </uxap:ObjectPageSubSection>
                    </uxap:subSections>
                </uxap:ObjectPageSection>

                <!-- Durum öznitelikleri -->
                <uxap:ObjectPageSection title="{i18n>sectionAttributes}" titleUppercase="false">
                    <uxap:subSections>
                        <uxap:ObjectPageSubSection titleUppercase="false">
                            <Table items="{em>attributes}" showSeparators="Inner">
                                <columns>
                                    <Column width="16rem">
                                        <Text text="{i18n>colAttrName}"/>
                                    </Column>
                                    <Column>
                                        <Text text="{i18n>colAttrValue}"/>
                                    </Column>
                                </columns>
                                <items>
                                    <ColumnListItem>
                                        <cells>
                                            <Label text="{em>name}"/>
                                            <Text text="{em>value}"/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </uxap:ObjectPageSubSection>
                    </uxap:subSections>
                </uxap:ObjectPageSection>

            </uxap:sections>

            <uxap:footer>
                <OverflowToolbar>
                    <ToolbarSpacer/>
                    <Button
                        text="{i18n>reportEvent}"
                        type="Emphasized"
                        icon="sap-icon://add-activity"
                        press=".onOpenReportDialog"/>
                </OverflowToolbar>
            </uxap:footer>

        </uxap:ObjectPageLayout>
    </Page>
</mvc:View>
